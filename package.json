{
    "name": "cortex",
    "type": "module",
    "private": false,
    "version": "0.6.6",
    "workspaces": [
        "packages/*"
    ],
    "devDependencies": {
        "@changesets/cli": "^2.29.8",
        "@eslint/js": "^9.39.3",
        "@stylistic/eslint-plugin": "5.7.1",
        "@types/bun": "latest",
        "@types/express": "^5.0.6",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^9.39.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "prettier": "^3.8.1",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@commander-js/extra-typings": "^14.0.0",
        "@modelcontextprotocol/sdk": "^1.27.1",
        "@toon-format/toon": "^1.4.0",
        "commander": "^14.0.3",
        "express": "^5.2.1",
        "zod": "^4.3.6"
    },
    "scripts": {
        "build": "bun run --filter '@yeseh/cortex-core' build && bun run --filter '!@yeseh/cortex-core' build",
        "test": "bun test packages",
        "test:core": "bun test packages/core",
        "test:cli": "bun test packages/cli",
        "test:server": "bun test packages/server",
        "test:storage-fs": "bun test packages/storage-fs",
        "lint": "bunx eslint packages/*/src/**/*.ts --fix",
        "format": "prettier --write \"packages/*/src/**/*.{ts,json,md}\"",
        "format:check": "prettier --check \"packages/*/src/**/*.{ts,json,md}\"",
        "typecheck": "bun tsc --build",
        "clean": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo",
        "compile:mcp": "bun build --compile --minify --sourcemap --bytecode ./packages/server/src/index.ts --outfile ./bin/cortex-mcp",
        "compile:cli": "bun build --compile --minify --sourcemap --bytecode ./packages/cli/src/run.ts --outfile ./bin/cortex",
        "changeset": "changeset",
        "publish:dry": "for dir in packages/*; do (cd \"$dir\" && bun publish --dry-run --access public --provenance) || exit 1; done",
        "ci:version": "changeset version && bun update",
        "ci:publish": "for dir in packages/*; do (cd \"$dir\" && bun publish --access public --tolerate-republish --provenance) || exit 1; done && changeset tag",
        "version": "changeset version"
    }
}
