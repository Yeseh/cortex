{
    "name": "@yeseh/cortex-core",
    "version": "0.6.7",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Yeseh/cortex.git",
        "directory": "packages/core"
    },
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "bun": "./src/index.ts",
            "types": "./src/index.ts",
            "import": "./dist/index.js"
        },
        "./memory": {
            "bun": "./src/memory/index.ts",
            "types": "./src/memory/index.ts",
            "import": "./dist/memory/index.js"
        },
        "./category": {
            "bun": "./src/category/index.ts",
            "types": "./src/category/index.ts",
            "import": "./dist/category/index.js"
        },
        "./store": {
            "bun": "./src/store/index.ts",
            "types": "./src/store/index.ts",
            "import": "./dist/store/index.js"
        },
        "./storage": {
            "bun": "./src/storage/index.ts",
            "types": "./src/storage/index.ts",
            "import": "./dist/storage/index.js"
        }
    },
    "files": [
        "src",
        "dist"
    ],
    "scripts": {
        "build": "rm -f tsconfig.tsbuildinfo && bun run build.ts && tsc && tsc-alias -p tsconfig.json",
        "test": "bun test"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "zod": "^4.3.6",
        "@toon-format/toon": "^1.4.0"
    },
    "sideEffects": false,
    "description": "Core domain logic for the Cortex memory system. This package provides types, validation, and business logic for memories, categories, stores, and indexing.",
    "devDependencies": {},
    "keywords": [],
    "author": "",
    "bugs": {
        "url": "https://github.com/Yeseh/cortex/issues"
    },
    "homepage": "https://github.com/Yeseh/cortex#readme"
}
